# Application
APP_NAME=milo
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=mysql+pymysql://milo:milo123@localhost:3306/milo

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key

# Embedding
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=100
MIN_CHUNK_SIZE=100

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
RRF_K=60

# LLM
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
